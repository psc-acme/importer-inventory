{
    "name": "psc-acme/importer-inventory",
    "description": "Package importer-inventory for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ImporterInventory\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "aws/aws-sdk-php": "^3.332",
        "carbon/carbon": "^3.0",
        "doctrine/orm": "^3.0",
        "symfony/finder": "^7.0"
    },
    "require-dev": {
        "infection/infection": "^0.27",
        "rector/rector": "^1.0",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}